<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<?import java.lang.String?>
<AnchorPane stylesheets="@/fyzzbox/physicsapp/view/css/lighttheme.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <VBox alignment="CENTER" spacing="24.0" stylesheets="@../../css/lighttheme.css" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <Label alignment="CENTER" style="-fx-font-size: 80;" styleClass="heading-1" stylesheets="@../../css/lighttheme.css" text="Main Menu" />
            <HBox alignment="CENTER" spacing="40" stylesheets="@../../css/lighttheme.css">
               <children>
                  <Button styleClass="menu-card">
                     <graphic>
                        <VBox spacing="4">
                           <Label text="Load from Saved" styleClass="menu-card-title"/>
                           <Label text="Open a previously saved simulation" styleClass="menu-card-subtitle"/>
                        </VBox>
                     </graphic>
                  </Button>
                  <Button styleClass="menu-card">
                     <graphic>
                        <VBox spacing="4">
                           <Label text="Start New" styleClass="menu-card-title"/>
                           <Label text="Start a blank new simulation" styleClass="menu-card-subtitle"/>
                        </VBox>
                     </graphic>
                  </Button>
                  <Button styleClass="menu-card">
                     <graphic>
                        <VBox spacing="4">
                           <Label text="Settings" styleClass="menu-card-title"/>
                        </VBox>
                     </graphic>
                  </Button>
                  <Button styleClass="menu-card">
                     <graphic>
                        <VBox spacing="4">
                           <Label text="Back" styleClass="menu-card-title"/>
                        </VBox>
                     </graphic>
                  </Button>
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="48.0" left="48.0" right="48.0" top="48.0" />
         </padding>
      </VBox>
   </children>
   <padding>
      <Insets bottom="100.0" left="100.0" right="100.0" top="100.0" />
   </padding>

</AnchorPane>
