<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="fyzzbox.physicsapp.controller.SimulationController">
    <top>
        <HBox spacing="8.0">
            <padding>
                <Insets top="8.0" right="8.0" bottom="8.0" left="8.0"/>
            </padding>
            <Button text="Back" onAction="#onBackClicked"/>
            <Button text="Inspector" onAction="#onInspectorClicked"/>
        </HBox>
    </top>

    <center>
        <Pane fx:id="simulationPane" prefWidth="1000.0" prefHeight="700.0"/>
    </center>
</BorderPane>
